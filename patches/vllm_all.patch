+def _convert_mxfp4_to_nvfp4_scales(
+    ue8m0_scales: torch.Tensor,
+    block_size_mxfp4: int = 32,
+    block_size_nvfp4: int = 16,
+) -> tuple[torch.Tensor, torch.Tensor]:
+    """Convert MXFP4 UE8M0 scales to NVFP4 UE4M3 swizzled scales.
+
+    Returns (ue4m3_swizzled, alphas) where alphas compensate for UE4M3
+    range clipping (max=448).
+    """
+    from vllm.model_executor.layers.quantization.utils.nvfp4_utils import (
+        swizzle_blockscale,
+    )
+
+    assert ue8m0_scales.dtype == torch.uint8
+    orig_shape = ue8m0_scales.shape  # [E, N, K/32]
+    E = orig_shape[0]
+
+    # UE8M0 -> float: 2^(exponent - 127)
+    float_scales = torch.pow(
+        2.0, ue8m0_scales.to(torch.float32) - 127.0
+    )
+
+    # Per-expert alpha: compensate for UE4M3 range clipping (>448)
+    max_per_expert = float_scales.view(E, -1).max(dim=1).values
+    ue4m3_max = torch.tensor(448.0, device=max_per_expert.device)
+    alphas = torch.where(
+        max_per_expert > ue4m3_max,
+        max_per_expert / ue4m3_max,
+        torch.ones_like(max_per_expert),
+    )
+
+    # Scale down by alpha, then clip to UE4M3 range
+    float_scales_adj = float_scales / alphas.view(E, 1, 1)
+
+    # Block 32 -> 16: duplicate each scale for two sub-blocks
+    assert block_size_mxfp4 == 2 * block_size_nvfp4
+    ratio = block_size_mxfp4 // block_size_nvfp4
+    float_scales_16 = float_scales_adj.unsqueeze(-1).expand(
+        *float_scales_adj.shape, ratio
+    ).reshape(E, orig_shape[1], orig_shape[2] * ratio)
+
+    # Cast to float8_e4m3fn
+    ue4m3_scales = float_scales_16.to(torch.float8_e4m3fn)
+
+    # Swizzle for CUTLASS tensor core layout
+    ue4m3_swizzled = swizzle_blockscale(ue4m3_scales)
+
+    return ue4m3_swizzled, alphas
+
 
