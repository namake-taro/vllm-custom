+class Mxfp4LinearMethod(LinearMethodBase):
+    """MXFP4 online quantization for dense linear layers (qkv_proj, o_proj).
+
+    Loads BF16 weights, quantizes to FP4 in process_weights_after_loading,
+    and uses Marlin FP4 kernel for inference.
+    """
+
+    def create_weights(
+        self,
+        layer: torch.nn.Module,
+        input_size_per_partition: int,
+        output_partition_sizes: list[int],
+        input_size: int,
+        output_size: int,
+        params_dtype: torch.dtype,
+        **extra_weight_attrs,
+    ):
+        K = input_size_per_partition
+        N = sum(output_partition_sizes)
+
+        # Marlin alignment: K % 64 == 0, N % 128 == 0
+        K_padded = round_up(K, 64)
+        N_padded = round_up(N, 128)
+
+        layer._mxfp4_K = K
+        layer._mxfp4_N = N
+        layer._mxfp4_K_padded = K_padded
+        layer._mxfp4_N_padded = N_padded
+
+        weight_loader = extra_weight_attrs.pop("weight_loader")
+        weight = ModelWeightParameter(
+            data=torch.empty(N, K, dtype=params_dtype),
+            input_dim=1,
+            output_dim=0,
+            weight_loader=weight_loader,
+        )
+        layer.register_parameter("weight", weight)
+        set_weight_attrs(weight, extra_weight_attrs)
+
+        layer.params_dtype = params_dtype
+
+    def process_weights_after_loading(self, layer: torch.nn.Module) -> None:
+        from vllm.model_executor.layers.quantization.utils.mxfp4_utils import (
+            mxfp4_e2m1_quantize,
+        )
+
+        K = layer._mxfp4_K
+        N = layer._mxfp4_N
+        K_padded = layer._mxfp4_K_padded
+        N_padded = layer._mxfp4_N_padded
+
+        weight_bf16 = layer.weight.data  # (N, K)
+
+        # Pad to Marlin alignment
+        if K_padded != K or N_padded != N:
+            padded = torch.zeros(
+                N_padded, K_padded,
+                dtype=weight_bf16.dtype, device=weight_bf16.device,
+            )
+            padded[:N, :K] = weight_bf16
+            weight_bf16 = padded
+
+        # BF16 -> FP4 quantize
+        quant, scales = mxfp4_e2m1_quantize(weight_bf16)
+        del weight_bf16
+
+        # Set attributes for prepare_fp4_layer_for_marlin
+        replace_parameter(layer, "weight", quant)
+        layer.weight_scale = Parameter(scales, requires_grad=False)
+        layer.output_size_per_partition = N_padded
+        layer.input_size_per_partition = K_padded
+
+        # Pad bias if N was padded
+        if hasattr(layer, "bias") and layer.bias is not None and N_padded != N:
+            padded_bias = torch.zeros(
+                N_padded, dtype=layer.bias.dtype, device=layer.bias.device,
+            )
+            padded_bias[:N] = layer.bias.data
+            layer.bias = Parameter(padded_bias, requires_grad=False)
+
+        prepare_fp4_layer_for_marlin(layer, input_dtype=get_marlin_input_dtype())
+        torch.cuda.empty_cache()
+
+        logger.info(
+            f"[MXFP4] Linear quantized: ({N},{K}) -> "
+            f"({N_padded},{K_padded}) FP4+Marlin"
+        )
+
+    def apply(
+        self,
+        layer: torch.nn.Module,
+        x: torch.Tensor,
+        bias: torch.Tensor | None = None,
+    ) -> torch.Tensor:
+        K = layer._mxfp4_K
+        N = layer._mxfp4_N
+        K_padded = layer._mxfp4_K_padded
+        N_padded = layer._mxfp4_N_padded
+
+        # Pad input if K was padded
+        if K_padded != K:
+            pad = torch.zeros(
+                *x.shape[:-1], K_padded - K,
+                dtype=x.dtype, device=x.device,
+            )
+            x = torch.cat([x, pad], dim=-1)
+
+        output = apply_fp4_marlin_linear(
+            input=x,
+            weight=layer.weight,
+            weight_scale=layer.weight_scale,
+            weight_global_scale=None,
+            workspace=layer.workspace,
+            size_n=N_padded,
+            size_k=K_padded,
+            bias=bias,
+        )
+
+        # Slice output if N was padded
+        if N_padded != N:
+            output = output[..., :N].contiguous()
+
+        return output
+
